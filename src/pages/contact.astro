---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Contact Us" description="Contact TFILM.">
  <section class="section contact-page">
    <div class="page-shell contact-shell">
      <header class="contact-heading">
        <p class="eyebrow">Studio / Production</p>
        <h1>CONTACT US</h1>
      </header>

      <div class="contact-grid">
        <form class="contact-form" action="mailto:info@tfilm.it" method="post" enctype="text/plain">
          <div class="field-row">
            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="given-name" required />
            </label>
            <label>
              <span>Surname</span>
              <input type="text" name="surname" autocomplete="family-name" required />
            </label>
          </div>

          <label>
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>

          <label>
            <span>Subject</span>
            <input type="text" name="subject" required />
          </label>

          <label>
            <span>Message</span>
            <textarea name="message" rows="7" required></textarea>
          </label>

          <button type="submit">Send</button>
        </form>

        <aside class="contact-card" aria-label="TFILM contact information">
          <div class="contact-details">
            <h2>TFILM</h2>
            <p>
              Via della magliana 854<br />
              00148 - Roma<br />
              ITALY
            </p>
            <a href="mailto:info@tfilm.it">info@tfilm.it</a>
          </div>

          <div class="map-frame" aria-label="Map showing TFILM location">
            <iframe
              title="TFILM map"
              src="https://www.google.com/maps?q=Via%20della%20Magliana%20854%2C%2000148%20Roma%2C%20Italy&z=12&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    min-height: calc(100vh - 6.1rem);
    display: grid;
    align-items: center;
  }

  .contact-shell {
    display: grid;
    gap: clamp(2.6rem, 6vw, 5rem);
  }

  .contact-heading {
    display: grid;
    gap: 0.9rem;
  }

  h1 {
    margin: 0;
    color: rgba(242, 238, 229, 0.9);
    font-family: "Julius Sans One", var(--font-sans);
    font-size: clamp(3.4rem, 9.5vw, 8.5rem);
    font-weight: 400;
    letter-spacing: 0.18em;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .contact-form {
    display: grid;
    gap: 1.35rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.42rem;
    color: rgba(242, 238, 229, 0.72);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid rgba(242, 238, 229, 0.18);
    border-radius: 0;
    background: rgba(242, 238, 229, 0.035);
    color: var(--color-text);
    padding: 0.9rem 1rem;
    outline: none;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  textarea:focus {
    border-color: rgba(216, 179, 95, 0.72);
    background: rgba(242, 238, 229, 0.055);
    box-shadow: 0 0 0 1px rgba(216, 179, 95, 0.18);
  }

  button {
    width: fit-content;
    min-width: 8.5rem;
    border: 1px solid rgba(216, 179, 95, 0.58);
    border-radius: 0;
    background: rgba(216, 179, 95, 0.04);
    color: var(--color-accent);
    padding: 0.9rem 1.35rem;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      color 160ms ease,
      background 160ms ease;
  }

  button:hover {
    border-color: rgba(216, 179, 95, 0.92);
    background: rgba(216, 179, 95, 0.1);
    color: var(--color-text);
  }

  .contact-card {
    display: grid;
    gap: 1.4rem;
  }

  .contact-details {
    display: grid;
    gap: 0.85rem;
    color: rgba(242, 238, 229, 0.72);
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .contact-details h2,
  .contact-details p {
    margin: 0;
  }

  .contact-details h2 {
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-details a {
    width: fit-content;
    color: var(--color-accent);
    text-decoration: none;
  }

  .map-frame {
    position: relative;
    min-height: 17rem;
    overflow: hidden;
    border: 1px solid rgba(242, 238, 229, 0.16);
    background:
      linear-gradient(135deg, rgba(216, 179, 95, 0.12), transparent 42%),
      rgba(242, 238, 229, 0.035);
  }

  .map-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    filter: grayscale(1) invert(0.9) contrast(0.9) brightness(0.72);
    opacity: 0.72;
  }

  @media (max-width: 820px) {
    .contact-grid,
    .field-row {
      grid-template-columns: 1fr;
    }

    h1 {
      letter-spacing: 0.1em;
    }
  }
</style>
