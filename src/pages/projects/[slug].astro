---
import ResponsiveImage from "@components/media/ResponsiveImage.astro";
import TrailerModal from "@components/media/TrailerModal.astro";
import { projects } from "@data/projects";
import { isFilmsEditorialOnline } from "@data/site-control";
import BaseLayout from "@layouts/BaseLayout.astro";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
if (!isFilmsEditorialOnline()) {
  return Astro.redirect("/");
}

const stills = project.assets.filter((asset) => asset.kind === "still");
const backstage = project.assets.filter((asset) => asset.kind === "backstage");
const institutional = project.assets.filter((asset) => asset.kind === "institutional");
---

<BaseLayout title={project.title} description={project.summary}>
  <article class="project-page">
    <header class="project-hero page-shell">
      <div class="project-heading">
        <p class="eyebrow">{project.year} / {project.status}</p>
        <h1>{project.title}</h1>
        <p class="muted">{project.byline}</p>
      </div>
      <ResponsiveImage src={project.poster.src} alt={project.poster.alt} loading="eager" />
    </header>

    <section class="section">
      <div class="page-shell project-body">
        <p>{project.synopsis}</p>
        <div class="actions">
          {
            project.videos.map((video) => (
              <button type="button" data-vimeo-id={video.vimeoId} data-vimeo-title={video.title}>
                {video.label}
              </button>
            ))
          }
        </div>
        <div class="technical">
          <h2>Technical information</h2>
          <ul>
            {project.technicalInfo.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        {
          institutional.length > 0 && (
            <div class="institutional">
              {institutional.map((asset) => <img src={asset.src} alt={asset.alt} loading="lazy" />)}
            </div>
          )
        }
        {
          stills.length > 0 && (
            <div class="still-grid">
              {stills.map((asset) => <ResponsiveImage src={asset.src} alt={asset.alt} />)}
            </div>
          )
        }
        {
          backstage.length > 0 && (
            <div class="still-grid">
              {backstage.map((asset) => <ResponsiveImage src={asset.src} alt={asset.alt} />)}
            </div>
          )
        }
      </div>
    </section>
  </article>
  <TrailerModal />
</BaseLayout>

<style>
  .project-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 28rem);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: end;
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  .project-heading {
    display: grid;
    gap: 1rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.95;
  }

  p {
    margin: 0;
  }

  .project-body {
    display: grid;
    gap: 2rem;
  }

  .project-body > p {
    max-width: 48rem;
    color: var(--color-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .actions button {
    border: 1px solid var(--color-line);
    color: var(--color-accent);
    background: rgba(242, 238, 229, 0.04);
    padding: 0.85rem 1rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .technical {
    border-top: 1px solid var(--color-line);
    padding-top: 1.5rem;
  }

  h2 {
    margin: 0 0 1rem;
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  ul {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    color: var(--color-muted);
    list-style: none;
  }

  .institutional img {
    max-width: min(100%, 24rem);
    filter: grayscale(1) brightness(1.25);
  }

  .still-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  @media (max-width: 760px) {
    .project-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
