---
type Props = {
  id: string;
  title: string;
};

const { id, title } = Astro.props;
---

<div class="video-frame">
  <iframe
    src={`https://player.vimeo.com/video/${id}`}
    title={title}
    allow="autoplay; fullscreen; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

<style>
  .video-frame {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
