---
import ResponsiveImage from "@components/media/ResponsiveImage.astro";
import { heroImages } from "@data/home";
---

<section class="hero" id="top" aria-labelledby="home-title">
  <div class="hero-frame" aria-label="Featured TFILM imagery">
    {heroImages.map((image) => <ResponsiveImage src={image.src} alt={image.alt} loading="eager" />)}
  </div>

  <div class="page-shell hero-copy">
    <p class="eyebrow">TFILM.IT</p>
    <h1 id="home-title">Cinema held in stillness.</h1>
    <p>
      Independent films, visual research, and production archives gathered in a
      lean portfolio built for images, trailers, credits, and future projects.
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 4.8rem);
    display: grid;
    align-items: end;
    padding-bottom: clamp(2rem, 5vw, 4.5rem);
    overflow: hidden;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    display: grid;
    gap: clamp(0.8rem, 2vw, 1.4rem);
  }

  h1 {
    max-width: 11ch;
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(3.8rem, 11vw, 10.5rem);
    font-weight: 500;
    line-height: 0.86;
    text-shadow: 0 0.2rem 2.8rem rgba(0, 0, 0, 0.72);
  }

  p {
    margin: 0;
  }

  .hero-copy > p:last-child {
    max-width: 40rem;
    color: rgba(242, 238, 229, 0.78);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    text-shadow: 0 0.1rem 1.6rem rgba(0, 0, 0, 0.9);
  }

  .hero-frame {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    min-height: 100%;
  }

  .hero-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(15, 15, 13, 0.92), rgba(15, 15, 13, 0.42) 48%, rgba(15, 15, 13, 0.68)),
      linear-gradient(0deg, rgba(15, 15, 13, 0.95), transparent 44%),
      linear-gradient(180deg, rgba(15, 15, 13, 0.42), transparent 30%);
  }

  .hero-frame :global(img) {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    filter: saturate(0.82) contrast(1.08);
  }

  .hero-frame :global(img:nth-child(n + 2)) {
    display: none;
  }

  @media (max-width: 820px) {
    .hero {
      min-height: calc(92vh - 4.8rem);
    }

    h1 {
      font-size: clamp(3.4rem, 18vw, 6.4rem);
    }

    .hero-frame::after {
      background:
        linear-gradient(90deg, rgba(15, 15, 13, 0.88), rgba(15, 15, 13, 0.5)),
        linear-gradient(0deg, rgba(15, 15, 13, 0.95), transparent 52%);
    }
  }
</style>
